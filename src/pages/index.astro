---
import { AsciiApp } from "../components/AsciiApp";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Convert images into customizable ASCII art directly in your browser."
    />
    <link rel="icon" type="image/png" href="/picascii-logo.png" />
    <link rel="apple-touch-icon" href="/picascii-logo.png" />
    <title>Image to ASCII</title>
  </head>
  <body class="min-h-screen">
    <main class="mx-auto w-[calc(100%_-_2rem)] max-w-[1220px] py-5 md:py-8">
      <header class="mb-6 flex flex-col gap-5 rounded-lg border border-zinc-200 bg-white p-5 shadow-[0_16px_45px_rgba(24,24,27,0.06)] md:mb-8 md:flex-row md:items-center md:justify-between">
        <div class="flex items-center gap-4">
          <img
            class="size-16 rounded-lg border border-zinc-200 bg-zinc-50 object-cover md:size-20"
            src="/picascii-logo.png"
            alt="Image to ASCII logo"
          />
          <div>
            <p class="mb-1 text-xs font-black uppercase tracking-[0.22em] text-teal-700">
              Browser canvas tool
            </p>
            <h1 class="text-3xl font-black leading-none tracking-normal text-zinc-950 md:text-5xl">
              Image to ASCII
            </h1>
          </div>
        </div>
        <p class="max-w-xl text-base leading-7 text-zinc-500 md:text-right">
          Upload an image, tune the output settings, then copy or download crisp ASCII
          art generated entirely in your browser.
        </p>
      </header>

      <AsciiApp client:load />
    </main>
  </body>
</html>
