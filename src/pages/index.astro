---
import { AsciiApp } from "../components/AsciiApp";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Convert images into customizable ASCII art directly in your browser."
    />
    <title>Image to ASCII</title>
  </head>
  <body>
    <main class="mx-auto w-[calc(100%_-_2rem)] max-w-[1180px] py-6 md:py-12">
      <header class="mb-8">
        <h1 class="text-[clamp(2.1rem,5vw,4.5rem)] font-black leading-none tracking-normal text-slate-950">
          Image to ASCII
        </h1>
        <p class="mt-4 max-w-2xl text-lg text-slate-500">
          Upload an image, tune the output settings, then copy or download the generated
          ASCII art.
        </p>
      </header>

      <AsciiApp client:load />
    </main>
  </body>
</html>
